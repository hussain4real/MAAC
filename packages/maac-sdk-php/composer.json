{
    "name": "milaha/maac-sdk",
    "description": "Framework-agnostic PHP client for the Milaha AI Agent Center (MAAC) SDK & runtime API: token exchange, manifest sync, implementation reporting, and pause/resume agent runs.",
    "type": "library",
    "version": "0.1.0",
    "license": "MIT",
    "keywords": [
        "maac",
        "milaha",
        "ai",
        "agent",
        "sdk"
    ],
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "Maac\\Sdk\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
