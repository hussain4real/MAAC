{
    "api_version": "1.0.0",
    "schema_validation": [
        {
            "name": "all base types valid",
            "schema": {
                "s": "string",
                "n": "number",
                "i": "integer",
                "b": "boolean",
                "o": "object",
                "a": "array"
            },
            "payload": {
                "s": "x",
                "n": 1.5,
                "i": 2,
                "b": true,
                "o": {
                    "k": "v"
                },
                "a": [
                    1,
                    2
                ]
            },
            "valid": true,
            "errors": []
        },
        {
            "name": "optional field omitted is valid",
            "schema": {
                "query": "string",
                "limit": "integer?"
            },
            "payload": {
                "query": "today"
            },
            "valid": true,
            "errors": []
        },
        {
            "name": "missing required field",
            "schema": {
                "query": "string",
                "total": "number"
            },
            "payload": {
                "total": 5
            },
            "valid": false,
            "errors": [
                "Missing required field \"query\"."
            ]
        },
        {
            "name": "wrong scalar type",
            "schema": {
                "n": "number"
            },
            "payload": {
                "n": "nope"
            },
            "valid": false,
            "errors": [
                "Field \"n\" must be of type number."
            ]
        },
        {
            "name": "integer rejects a float",
            "schema": {
                "i": "integer"
            },
            "payload": {
                "i": 1.5
            },
            "valid": false,
            "errors": [
                "Field \"i\" must be of type integer."
            ]
        },
        {
            "name": "boolean is not a number",
            "schema": {
                "n": "number"
            },
            "payload": {
                "n": true
            },
            "valid": false,
            "errors": [
                "Field \"n\" must be of type number."
            ]
        },
        {
            "name": "object rejects a list",
            "schema": {
                "o": "object"
            },
            "payload": {
                "o": [
                    1,
                    2
                ]
            },
            "valid": false,
            "errors": [
                "Field \"o\" must be of type object."
            ]
        },
        {
            "name": "array rejects an object",
            "schema": {
                "a": "array"
            },
            "payload": {
                "a": {
                    "k": "v"
                }
            },
            "valid": false,
            "errors": [
                "Field \"a\" must be of type array."
            ]
        },
        {
            "name": "format hint is ignored",
            "schema": {
                "d": "string·date"
            },
            "payload": {
                "d": "2026-01-01"
            },
            "valid": true,
            "errors": []
        },
        {
            "name": "extra fields are tolerated",
            "schema": {
                "query": "string"
            },
            "payload": {
                "query": "hi",
                "extra": true
            },
            "valid": true,
            "errors": []
        }
    ],
